@using IdentityMVC.Models
@{
    ViewData["Title"] = "Administration";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-danger">
    <strong>Zone réservée aux administrateurs.</strong>
    Seuls les utilisateurs ayant le rôle <em>Administrateur</em> peuvent accéder à cette page.
</div>

<h4>Fonctionnalités d'administration</h4>
<ul>
    <li>Gérer les utilisateurs</li>
    <li>Gérer les rôles</li>
    <li>Consulter les journaux d'activité</li>
    <li>Configurer l'application</li>
</ul>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Gestion" class="btn btn-warning">Espace gestion</a>
    <a asp-action="Index" class="btn btn-secondary">Retour à l'accueil</a>
</div>
