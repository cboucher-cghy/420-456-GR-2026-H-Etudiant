@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Accès refusé";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="alert alert-danger" role="alert">
                <h1 class="display-1">403</h1>
                <h2>Accès refusé</h2>
                <p class="lead">
                    Vous êtes connecté, mais vous n'avez pas les permissions nécessaires
                    pour accéder à cette page.
                </p>
                <hr />
                <p>
                    Si vous pensez qu'il s'agit d'une erreur, contactez un administrateur.
                </p>
            </div>

            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                    Retour à l'accueil
                </a>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-secondary">
                    Se connecter avec un autre compte
                </a>
            </div>
        </div>
    </div>
</div>
