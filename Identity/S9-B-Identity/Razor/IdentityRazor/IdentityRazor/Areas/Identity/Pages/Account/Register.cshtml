@page
@model RegisterModel
@{
    ViewData["Title"] = "Inscription";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <h2>Créer un nouveau compte.</h2>
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Surnom" class="form-control" aria-required="true" placeholder="Surnom" />
                <label asp-for="Input.Surnom">Surnom</label>
                <span asp-validation-for="Input.Surnom" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Nom" class="form-control" aria-required="true" placeholder="Nom" />
                <label asp-for="Input.Nom">Nom</label>
                <span asp-validation-for="Input.Nom" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Adresse" class="form-control" placeholder="Adresse" />
                <label asp-for="Input.Adresse">Adresse</label>
                <span asp-validation-for="Input.Adresse" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="mot de passe" />
                <label asp-for="Input.Password">Mot de passe</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="mot de passe" />
                <label asp-for="Input.ConfirmPassword">Confirmer le mot de passe</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.TypeUtilisateur" class="form-label fw-bold">Type d'utilisateur</label>
                <select asp-for="Input.TypeUtilisateur" asp-items="Model.TypesUtilisateur" class="form-select" id="typeUtilisateur">
                    <option value="">-- Choisir un type --</option>
                </select>
                <span asp-validation-for="Input.TypeUtilisateur" class="text-danger"></span>
            </div>

            <!-- Section Employe -->
            <div id="section-employe" class="d-none">
                <h5 class="mt-2">Informations Employé</h5>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Poste" class="form-control" placeholder="Poste" />
                    <label asp-for="Input.Poste">Poste</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Departement" class="form-control" placeholder="Département" />
                    <label asp-for="Input.Departement">Département</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.DateEmbauche" class="form-control" type="date" />
                    <label asp-for="Input.DateEmbauche">Date d'embauche</label>
                </div>
            </div>

            <!-- Section Etudiant -->
            <div id="section-etudiant" class="d-none">
                <h5 class="mt-2">Informations Étudiant</h5>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Programme" class="form-control" placeholder="Programme" />
                    <label asp-for="Input.Programme">Programme</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.NumeroEtudiant" class="form-control" placeholder="Numéro étudiant" />
                    <label asp-for="Input.NumeroEtudiant">Numéro étudiant</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.DateInscription" class="form-control" type="date" />
                    <label asp-for="Input.DateInscription">Date d'inscription</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.MoyenneGenerale" class="form-control" placeholder="Moyenne générale" />
                    <label asp-for="Input.MoyenneGenerale">Moyenne générale</label>
                </div>
            </div>

            <!-- Section Enseignant -->
            <div id="section-enseignant" class="d-none">
                <h5 class="mt-2">Informations Enseignant</h5>
                <div class="form-floating mb-3">
                    <input asp-for="Input.MatiereEnseignee" class="form-control" placeholder="Matière enseignée" />
                    <label asp-for="Input.MatiereEnseignee">Matière enseignée</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.DateEmbauche" class="form-control" type="date" />
                    <label asp-for="Input.DateEmbauche">Date d'embauche</label>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Salaire" class="form-control" placeholder="Salaire" />
                    <label asp-for="Input.Salaire">Salaire</label>
                </div>
            </div>
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">S'inscrire</button>
        </form>
    </div>
    <div class="col-md-6 col-md-offset-2">
        <section>
            <h3>Utiliser un autre service pour s'inscrire.</h3>
            <hr />
            @{
                if ((Model.ExternalLogins?.Count ?? 0) == 0)
                {
                    <div>
                        <p>
                            Aucun service d'authentification externe n'est configuré. Consultez cet <a href="https://learn.microsoft.com/fr-ca/aspnet/core/security/authentication/social/?view=aspnetcore-10.0&tabs=visual-studio">
                            article
                            sur la configuration de cette application ASP.NET pour prendre en charge la connexion via des services externes</a>.
                        </p>
                    </div>
                }
                else
                {
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal">
                        <div>
                            <p>
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-primary" name="provider" value="@provider.Name" title="Se connecter avec votre compte @provider.DisplayName">@provider.DisplayName</button>
                                }
                            </p>
                        </div>
                    </form>
                }
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const typeSelect = document.getElementById('typeUtilisateur');
        const sections = ['employe', 'etudiant', 'enseignant'];

        function updateSections() {
            const val = typeSelect.value.toLowerCase();
            sections.forEach(type => {
                const el = document.getElementById('section-' + type);
                if (el) el.classList.toggle('d-none', type !== val);
            });
        }

        typeSelect.addEventListener('change', updateSections);
        updateSections();
    </script>
}
